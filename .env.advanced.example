# ============================================================================
# Hedger Bot — EXPERIMENTAL configuration
#
# ⚠️  The options below are NOT part of the supported v1 surface. Their setup,
# monitoring, and recovery paths are not as hardened as the core (loan-only /
# in-pool / pool-tick or CEX signal / single Safe+pool). Use only if you know
# what you're doing. Merge the ones you need into your .env.
# ============================================================================

# --- EXPERIMENTAL price signal: 'uniswap-pool' -----------------------------
# A DIFFERENT pool on the SAME token pair as the options pool.
#PRICE_SIGNAL_SOURCE=uniswap-pool
UNISWAP_SIGNAL_POOL_VERSION=v3
# v3: the Uniswap v3 pool contract address
UNISWAP_SIGNAL_POOL_ADDRESS=
# v4: the StateView contract + the pool id (bytes32)
UNISWAP_SIGNAL_STATE_VIEW_ADDRESS=
UNISWAP_SIGNAL_POOL_ID=

# --- EXPERIMENTAL hedge venue: 'cross-pool-uniswap' (spot rebalance) --------
# A JSON whitelist of Uniswap pools on the SAME token pair as the vault. The bot
# best-quotes across all of them each cycle and swaps the winner; the same list
# scopes UniversalRouter.execute. Mix v3 and v4 freely. Requires extra Roles
# scoping + token approvals — see runbook.md § Cross-pool venue (experimental).
#   v4 entry: {"version":"v4","fee":500,"tickSpacing":10,"hooks":"0x0000000000000000000000000000000000000000"}
#   v3 entry: {"version":"v3","fee":3000}
#HEDGE_VENUE=cross-pool-uniswap
HEDGE_POOLS=[{"version":"v4","fee":500,"tickSpacing":10},{"version":"v3","fee":3000}]
UNIVERSAL_ROUTER_ADDRESS=
PERMIT2_ADDRESS=
MULTISEND_ADDRESS=
