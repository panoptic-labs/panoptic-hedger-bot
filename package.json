{
  "license": "MIT",
  "name": "@panoptic-eng/hedger-bot",
  "version": "0.1.0-rc.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "onboard": "tsx scripts/setup.ts",
    "onboard:cleanup": "tsx scripts/onboardCleanup.ts",
    "doctor": "tsx scripts/doctor.ts",
    "preflight": "tsx scripts/doctor.ts",
    "status": "tsx scripts/status.ts",
    "activate": "tsx scripts/activate.ts",
    "deactivate": "tsx scripts/deactivate.ts",
    "health": "tsx scripts/health.ts",
    "build:runtime": "esbuild src/main.ts scripts/health.ts --bundle --platform=node --format=esm --packages=external --outdir=dist",
    "start:compiled": "node dist/src/main.js",
    "health:compiled": "node dist/scripts/health.js",
    "inspect:hedge": "tsx scripts/inspectHedge.ts",
    "deploy:safe-roles": "tsx scripts/deploySafeAndRoles.ts",
    "scope:bot-role": "tsx scripts/scopeBotRole.ts",
    "manage-role": "tsx scripts/manageRole.ts",
    "generate:idea": "tsx scripts/generateIdea.ts",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern 'dist/**' --max-warnings=0",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run",
    "security:test-fork": "vitest run --config vitest.fork.config.ts",
    "security:check-ws": "tsx scripts/checkWsVersion.ts",
    "docs:check": "node scripts/checkDocsLinks.mjs"
  },
  "dependencies": {
    "@panoptic-eng/sdk": "1.0.29",
    "@tanstack/react-query": "5.45.1",
    "dotenv": "^17.2.3",
    "react": "18.2.0",
    "tiny-invariant": "^1.3.1",
    "viem": "^2.41.2",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@remix-run/eslint-config": "2.12.0",
    "@safe-global/protocol-kit": "^5.2.0",
    "@tanstack/eslint-plugin-query": "5.91.2",
    "@types/node": "^24.10.0",
    "@types/ws": "^8.5.12",
    "concurrently": "^7.6.0",
    "esbuild": "0.25.12",
    "eslint": "8.57.1",
    "eslint-config-prettier": "8.10.2",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-simple-import-sort": "8.0.0",
    "msw": "^2.12.4",
    "prettier": "3.7.3",
    "tsx": "^4.19.2",
    "typescript": "^5.1.6",
    "viem-deal": "^2.0.4",
    "vite": "^5.4.2",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^2.0.5"
  },
  "packageManager": "pnpm@10.29.2+sha512.bef43fa759d91fd2da4b319a5a0d13ef7a45bb985a3d7342058470f9d2051a3ba8674e629672654686ef9443ad13a82da2beb9eeb3e0221c87b8154fff9d74b8"
}
